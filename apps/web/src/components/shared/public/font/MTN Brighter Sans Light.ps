% Add Zapf Dingbats to unicode font at 0x2700
%  But only if on the printer, else use notdef
%  gv, which has no Zapf, maps courier to the name
%  so we must check a bit more than is it null or not...
/ZapfDingbats findfont pop
/ZapfDingbats findfont null eq
{ true }
